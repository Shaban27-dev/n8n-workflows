    {
      "parameters": {
        "sendTo": "your-email@gmail.com",
        "subject": "=🚀 High-Value Lead: {{ $json[\"Company\"] }} (Score: {{ $json[\"Lead Score\"] }})",
        "message": "=<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<title>High-Value Lead Alert</title>\n</head>\n\n<body style=\"margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;\">\n\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f7fb;padding:40px 0;\">\n<tr>\n<td align=\"center\">\n\n<table width=\"700\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff;border-radius:12px;overflow:hidden;border:1px solid #e5e7eb;\">\n\n<tr>\n<td style=\"background:#0f172a;padding:30px;text-align:center;\">\n\n<div style=\"font-size:34px;\">🚀</div>\n\n<h1 style=\"margin:10px 0 5px;color:white;font-size:28px;\">\nHigh-Value Lead Identified\n</h1>\n\n<p style=\"margin:0;color:#cbd5e1;font-size:16px;\">\nAI Lead Enrichment & Qualification Pipeline\n</p>\n\n</td>\n</tr>\n\n<tr>\n<td style=\"padding:30px;\">\n\n<table width=\"100%\" cellpadding=\"0\">\n\n<tr>\n\n<td>\n\n<h2 style=\"margin:0;color:#111827;\">\nLead Score\n</h2>\n\n</td>\n\n<td align=\"right\">\n\n<span style=\"\nbackground:#16a34a;\ncolor:white;\npadding:10px 18px;\nborder-radius:20px;\nfont-weight:bold;\nfont-size:18px;\n\">\n{{ $json[\"Lead Score\"] }}/100\n</span>\n\n</td>\n\n</tr>\n\n</table>\n\n<p style=\"margin-top:20px;color:#4b5563;font-size:16px;line-height:1.6;\">\nA new lead has been automatically enriched, analyzed by AI, and classified as\n<strong>High Priority</strong>.\n</p>\n\n</td>\n</tr>\n\n<tr>\n\n<td style=\"padding:0 30px 30px;\">\n\n<h2 style=\"color:#1f2937;border-bottom:2px solid #eef2f7;padding-bottom:10px;\">\n📋 Lead Details\n</h2>\n\n<table width=\"100%\" cellpadding=\"10\" cellspacing=\"0\" style=\"border-collapse:collapse;\">\n\n<tr>\n<td width=\"35%\" style=\"background:#f8fafc;font-weight:bold;\">Name</td>\n<td>{{ $json.Name }}</td>\n</tr>\n\n<tr>\n<td style=\"background:#f8fafc;font-weight:bold;\">Company</td>\n<td>{{ $json.Company }}</td>\n</tr>\n\n<tr>\n<td style=\"background:#f8fafc;font-weight:bold;\">Email</td>\n<td>{{ $json.Email }}</td>\n</tr>\n\n<tr>\n<td style=\"background:#f8fafc;font-weight:bold;\">Priority</td>\n<td>\n<span style=\"background:#dc2626;color:white;padding:5px 12px;border-radius:15px;\">\n{{ $json.Priority }}\n</span>\n</td>\n</tr>\n\n<tr>\n<td style=\"background:#f8fafc;font-weight:bold;\">Budget</td>\n<td>${{ $json.Budget }}</td>\n</tr>\n\n<tr>\n<td style=\"background:#f8fafc;font-weight:bold;\">Estimated Deal Size</td>\n<td>{{ $json[\"Estimated Deal Size\"] }}</td>\n</tr>\n\n<tr>\n<td style=\"background:#f8fafc;font-weight:bold;\">Confidence</td>\n<td>{{ $json[\"Confidence Score\"] }}%</td>\n</tr>\n\n</table>\n\n</td>\n\n</tr>\n\n<tr>\n\n<td style=\"padding:0 30px 25px;\">\n\n<h2 style=\"color:#1f2937;border-bottom:2px solid #eef2f7;padding-bottom:10px;\">\n📝 Lead Summary\n</h2>\n\n<div style=\"\nbackground:#f8fafc;\npadding:18px;\nborder-left:5px solid #2563eb;\nborder-radius:8px;\nline-height:1.7;\ncolor:#374151;\n\">\n\n{{ $json[\"Lead Summary\"] }}\n\n</div>\n\n</td>\n\n</tr>\n\n<tr>\n\n<td style=\"padding:0 30px 25px;\">\n\n<h2 style=\"color:#1f2937;border-bottom:2px solid #eef2f7;padding-bottom:10px;\">\n⚠ Key Pain Points\n</h2>\n\n<div style=\"\nbackground:#fff7ed;\nborder-left:5px solid #f59e0b;\npadding:18px;\nborder-radius:8px;\ncolor:#374151;\nline-height:1.7;\n\">\n\n{{ $json[\"Pain Points\"] }}\n\n</div>\n\n</td>\n\n</tr>\n\n<tr>\n\n<td style=\"padding:0 30px 25px;\">\n\n<h2 style=\"color:#1f2937;border-bottom:2px solid #eef2f7;padding-bottom:10px;\">\n💡 Recommended Solution\n</h2>\n\n<div style=\"\nbackground:#ecfdf5;\npadding:18px;\nborder-left:5px solid #10b981;\nborder-radius:8px;\nline-height:1.7;\n\">\n\n{{ $json[\"Recommended Solution\"] }}\n\n</div>\n\n</td>\n\n</tr>\n\n<tr>\n\n<td style=\"padding:0 30px 25px;\">\n\n<h2 style=\"color:#1f2937;border-bottom:2px solid #eef2f7;padding-bottom:10px;\">\n🎯 Value Proposition\n</h2>\n\n<p style=\"line-height:1.8;color:#374151;\">\n\n{{ $json[\"Value Proposition\"] }}\n\n</p>\n\n</td>\n\n</tr>\n\n<tr>\n\n<td style=\"padding:0 30px 25px;\">\n\n<h2 style=\"color:#1f2937;border-bottom:2px solid #eef2f7;padding-bottom:10px;\">\n📬 Outreach Strategy\n</h2>\n\n<p style=\"line-height:1.8;color:#374151;\">\n\n{{ $json[\"Outreach Strategy\"] }}\n\n</p>\n\n</td>\n\n</tr>\n\n<tr>\n\n<td align=\"center\" style=\"padding:10px 30px 35px;\">\n\n<a href=\"mailto:{{ $json.Email }}\"\nstyle=\"\nbackground:#2563eb;\ncolor:white;\npadding:15px 34px;\ntext-decoration:none;\nborder-radius:8px;\nfont-size:17px;\nfont-weight:bold;\ndisplay:inline-block;\n\">\n\nContact Lead\n\n</a>\n\n</td>\n\n</tr>\n\n<tr>\n\n<td style=\"\nbackground:#f8fafc;\npadding:25px;\ntext-align:center;\nfont-size:13px;\ncolor:#6b7280;\n\">\n\nGenerated automatically by the\n<strong>AI Lead Enrichment & Qualification Pipeline</strong>\n\n<br><br>\n\nReview this opportunity promptly to maximize conversion potential.\n\n</td>\n\n</tr>\n\n</table>\n\n</td>\n</tr>\n</table>\n\n</body>\n</html>",
        "options": {
          "appendAttribution": false
        }
