    {
      "parameters": {
        "sendTo": "youremail@gmail.com",
        "subject": "=📋 Low-Priority Lead Logged: {{ $json[\"Company\"] }} (Score: {{ $json[\"Lead Score\"] }})",
        "message": "=<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<title>Low-Priority Lead Logged</title>\n</head>\n\n<body style=\"margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;\">\n\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f7fb;padding:40px 0;\">\n<tr>\n<td align=\"center\">\n\n<table width=\"700\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff;border-radius:12px;overflow:hidden;border:1px solid #e5e7eb;\">\n\n<!-- Header -->\n\n<tr>\n<td style=\"background:#334155;padding:30px;text-align:center;\">\n\n<div style=\"font-size:34px;\">📋</div>\n\n<h1 style=\"margin:10px 0 5px;color:#ffffff;font-size:28px;\">\nLow-Priority Lead Logged\n</h1>\n\n<p style=\"margin:0;color:#cbd5e1;font-size:16px;\">\nAI Lead Enrichment & Qualification Pipeline\n</p>\n\n</td>\n</tr>\n\n<!-- Score -->\n\n<tr>\n<td style=\"padding:30px;\">\n\n<table width=\"100%\">\n\n<tr>\n\n<td>\n<h2 style=\"margin:0;color:#111827;\">\nLead Score\n</h2>\n</td>\n\n<td align=\"right\">\n\n<span style=\"\nbackground:#64748b;\ncolor:white;\npadding:10px 18px;\nborder-radius:20px;\nfont-weight:bold;\nfont-size:18px;\n\">\n\n{{ $json[\"Lead Score\"] }}/100\n\n</span>\n\n</td>\n\n</tr>\n\n</table>\n\n<p style=\"margin-top:20px;color:#4b5563;font-size:16px;line-height:1.7;\">\n\nThis lead has been automatically evaluated by the AI Lead Enrichment & Qualification Pipeline and classified as <strong>Low Priority</strong>. No outreach has been initiated.\n\n</p>\n\n</td>\n</tr>\n\n<!-- Lead Details -->\n\n<tr>\n\n<td style=\"padding:0 30px 30px;\">\n\n<h2 style=\"color:#1f2937;border-bottom:2px solid #eef2f7;padding-bottom:10px;\">\n👤 Lead Details\n</h2>\n\n<table width=\"100%\" cellpadding=\"10\" cellspacing=\"0\" style=\"border-collapse:collapse;\">\n\n<tr>\n<td width=\"35%\" style=\"background:#f8fafc;font-weight:bold;\">Name</td>\n<td>{{ $json.Name }}</td>\n</tr>\n\n<tr>\n<td style=\"background:#f8fafc;font-weight:bold;\">Company</td>\n<td>{{ $json.Company }}</td>\n</tr>\n\n<tr>\n<td style=\"background:#f8fafc;font-weight:bold;\">Email</td>\n<td>{{ $json['Email '] }}</td>\n</tr>\n\n<tr>\n<td style=\"background:#f8fafc;font-weight:bold;\">Domain</td>\n<td>{{ $json.Domain }}</td>\n</tr>\n\n<tr>\n<td style=\"background:#f8fafc;font-weight:bold;\">Budget</td>\n<td>${{ $json.Budget }}</td>\n</tr>\n\n<tr>\n<td style=\"background:#f8fafc;font-weight:bold;\">Lead Score</td>\n<td>{{ $json[\"Lead Score\"] }}/100</td>\n</tr>\n\n<tr>\n<td style=\"background:#f8fafc;font-weight:bold;\">Confidence Score</td>\n<td>{{ $json[\"Confidence Score\"] ? $json[\"Confidence Score\"] + '%' : 'N/A (Low Priority)' }}</td>\n</tr>\n\n<tr>\n<td style=\"background:#f8fafc;font-weight:bold;\">Company Size</td>\n<td>{{ $json[\"Company Size\"] }}</td>\n</tr>\n\n<tr>\n<td style=\"background:#f8fafc;font-weight:bold;\">Corporate Email</td>\n<td>{{ $json[\"Corporate Email\"] }}</td>\n</tr>\n\n<tr>\n<td style=\"background:#f8fafc;font-weight:bold;\">Status</td>\n<td>{{ $json.Status }}</td>\n</tr>\n\n</table>\n\n</td>\n\n</tr>\n\n<!-- Qualification -->\n\n<tr>\n\n<td style=\"padding:0 30px 25px;\">\n\n<h2 style=\"color:#1f2937;border-bottom:2px solid #eef2f7;padding-bottom:10px;\">\n📉 Qualification Result\n</h2>\n\n<div style=\"\nbackground:#eff6ff;\npadding:18px;\nborder-left:5px solid #3b82f6;\nborder-radius:8px;\nline-height:1.7;\ncolor:#374151;\n\">\n\n<strong>Reason:</strong><br><br>\n\n{{ $json.Reason }}\n\n</div>\n\n</td>\n\n</tr>\n\n<!-- Recommendation -->\n\n<tr>\n\n<td style=\"padding:0 30px 25px;\">\n\n<h2 style=\"color:#1f2937;border-bottom:2px solid #eef2f7;padding-bottom:10px;\">\n💡 Recommendation\n</h2>\n\n<div style=\"\nbackground:#f8fafc;\npadding:18px;\nborder-left:5px solid #94a3b8;\nborder-radius:8px;\nline-height:1.8;\ncolor:#374151;\n\">\n\nStore this lead in the <strong>Low-Quality Leads</strong> database for future nurturing campaigns. If additional information becomes available or the lead profile changes, the lead can be reprocessed through the enrichment pipeline.\n\n</div>\n\n</td>\n\n</tr>\n\n<!-- Footer -->\n\n<tr>\n\n<td style=\"\nbackground:#f8fafc;\npadding:25px;\ntext-align:center;\nfont-size:13px;\ncolor:#6b7280;\n\">\n\nGenerated automatically by the\n<strong>AI Lead Enrichment & Qualification Pipeline</strong>\n\n<br><br>\n\nThis notification is for internal tracking purposes only.\n\n</td>\n\n</tr>\n\n</table>\n\n</td>\n</tr>\n</table>\n\n</body>\n</html>",
        "options": {}
